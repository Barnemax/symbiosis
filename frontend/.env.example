# Better Auth generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# PostgreSQL connection for auth tables
AUTH_DATABASE_URL=postgres://symbiosis:symbiosis@localhost:5432/symbiosis

# API key for Symfony write operations
ADMIN_PASSWORD=

# API URL — Docker uses API_INTERNAL_URL (container network), browser uses NEXT_PUBLIC_API_URL
# API_INTERNAL_URL=http://php:80
# NEXT_PUBLIC_API_URL=http://localhost:8080

# Public site URL — used for sitemaps, canonical URLs, and OG metadata
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Brevo transactional email (contact form)
BREVO_API_KEY=
CONTACT_EMAIL=
CONTACT_SENDER_EMAIL=

# Cloudflare Turnstile (contact form captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
