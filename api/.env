###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://${POSTGRES_USER:-symbiosis}:${POSTGRES_PASSWORD:-symbiosis}@postgres:5432/${POSTGRES_DB:-symbiosis}?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/cache ###
REDIS_URL=redis://localhost:6379
###< symfony/cache ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

# API authentication (X-API-Key header for write operations)
# Set ADMIN_PASSWORD in .env.local

# xeno-canto API key (optional, only needed for app:import-media --audio)
# Set XENO_CANTO_API_KEY in .env.local
